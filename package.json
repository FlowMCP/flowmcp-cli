{
    "name": "flowmcp-cli",
    "version": "4.2.0",
    "description": "CLI for developing and validating FlowMCP schemas",
    "type": "module",
    "license": "MIT",
    "author": "FlowMCP",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/FlowMCP/flowmcp-cli.git"
    },
