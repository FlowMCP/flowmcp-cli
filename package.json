        "flowmcp": "github:FlowMCP/flowmcp-core#de3a08888fa3945a284203d3c6ecd1419caab2bc",
        "flowmcp-grading": "github:FlowMCP/flowmcp-grading#v2.0.0",
        "csv-tsv-sqlite-toolkit": "github:FlowMCP/csv-tsv-sqlite-toolkit#b08b5288926b2620bf30b4d1b2571c574e1511bf",
